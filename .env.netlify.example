# Storefront — Netlify Environment Variables

# Medusa Backend (your Railway URL)
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://your-medusa-service.up.railway.app

# Medusa Publishable Key (create via Medusa admin after deployment)
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_your_key_from_railway
MEDUSA_PUBLISHABLE_KEY=pk_your_key_from_railway

# Convex (optional — for real-time features)
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# Stripe (get from https://dashboard.stripe.com/test/apikeys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Auth
JWT_SECRET=generate-with-openssl-rand--base64-32
NEXTAUTH_SECRET=generate-with-openssl-rand--base64-32
NEXTAUTH_URL=https://your-app.netlify.app
