# Medusa Backend — Railway Environment Variables

# Database (Railway auto-sets these when you add PostgreSQL)
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# Redis (Railway auto-sets this when you add Redis)
# REDIS_URL=${{Redis.DATABASE_URL}}

# Medusa Configuration
MEDUSA_BACKEND_URL=https://your-medusa-service.up.railway.app
JWT_SECRET=generate-a-random-string-here
COOKIE_SECRET=generate-another-random-string-here

# CORS - Your storefront URL
STORE_CORS=https://your-storefront.vercel.app
ADMIN_CORS=https://your-storefront.vercel.app
AUTH_CORS=https://your-storefront.vercel.app

# Stripe (get from https://dashboard.stripe.com/test/apikeys)
STRIPE_API_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Convex (get from https://convex.dev)
CONVEX_URL=https://your-project.convex.cloud
CONVEX_ADMIN_KEY=your_convex_admin_key

# Optional: Production mode
NODE_ENV=production
