# ============================================================
# Environment Variables Template — Frontend (Storefront)
# Copy this file to .env.local and fill in the values.
# ============================================================

# --- Medusa Backend ---
# Base URL of your running Medusa instance
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# --- Convex ---
# Your Convex deployment URL
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# --- Stripe ---
# Publishable key (safe for client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key

# --- Auth (NextAuth + JWT) ---
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-in-production
NEXTAUTH_SECRET=change-me-too
# Your production URL (used for redirects)
NEXTAUTH_URL=http://localhost:3000

# --- Stripe Webhook ---
# From Stripe Dashboard > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# --- App ---
NODE_ENV=development
