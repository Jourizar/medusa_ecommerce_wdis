{
  "name": "@ecommerce/medusa-backend",
  "version": "0.1.0",
  "description": "Medusa.js v2 commerce backend with Stripe and Convex sync",
  "author": "URBN",
  "license": "MIT",
  "keywords": [
    "medusa",
    "commerce",
    "ecommerce",
    "headless"
  ],
  "scripts": {
    "dev": "medusa develop",
    "build": "medusa build",
    "start": "medusa start",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "db:setup": "medusa db:setup",
    "db:migrate": "medusa db:migrate",
    "migrations:run": "medusa db:migrate",
    "migrations:generate": "medusa db:generate",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "^2.0.0",
    "@medusajs/cli": "^2.0.0",
    "@medusajs/framework": "^2.0.0",
    "@medusajs/medusa": "^2.0.0",
    "@mikro-orm/core": "^6.6.12",
    "@mikro-orm/knex": "^6.6.12",
    "@mikro-orm/migrations": "^6.6.12",
    "@mikro-orm/postgresql": "^6.6.12",
    "awilix": "^8.0.1",
    "convex": "^1.18.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
